# Base URL path (default: /)
BASE_URL=/

# API prefix path. Default is /crm-api (used by Replit dev proxy).
# For production deployments where backend is at /api, set:
# VITE_API_PREFIX=/api
VITE_API_PREFIX=/crm-api

# Backend API URL. Leave empty to use the Vite proxy.
# Set to the full backend origin when hosted separately, e.g.:
# VITE_API_URL=https://api.yourdomain.com/crm-api
VITE_API_URL=localhost:3001/crm-api
